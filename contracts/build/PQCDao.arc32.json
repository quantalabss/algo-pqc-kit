    "contract": {
        "name": "PQCDao",
        "desc": "\n    Post-Quantum DAO\n\n    A decentralized autonomous organization where all governance\n    decisions are authorized by Falcon-1024 multi-signatures verified\n    on-chain. No Ed25519. No classical multisig. Fully PQC.\n\n    Governance flow\n    ---------------\n    1. Any committee member creates a proposal (spending amount + recipient)\n    2. Committee members sign the proposal message off-chain (Falcon-1024)\n    3. Proposer submits M signatures \u2192 contract verifies on-chain\n    4. If M-of-N verified \u2192 proposal executes, treasury pays out\n\n    Storage layout (box storage)\n    ----------------------------\n    b\"pk_{index:8}\"      \u2192 Falcon-1024 public key (1793 bytes)\n    b\"prop_{id:8}\"       \u2192 Proposal data (ABI-encoded)\n    ",
        "methods": [
            {
                "name": "create",
                "args": [
                    {
                        "type": "string",
                        "name": "dao_name",
                        "desc": "Human-readable name for the DAO."
                    },
                    {
                        "type": "uint64",
                        "name": "threshold",
                        "desc": "M \u2014 minimum Falcon-1024 signatures required to pass a proposal."
                    },
                    {
                        "type": "byte[][]",
                        "name": "public_keys",
                        "desc": "Falcon-1024 public keys of all N committee members."
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Initialize the DAO."
            },
            {
                "name": "bootstrap",
                "args": [
                    {
                        "type": "byte[][]",
                        "name": "public_keys"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Allocate boxes for the public keys.\nRequires the app to be funded first."
            },
            {
                "name": "submit_proposal",
                "args": [
                    {
                        "type": "string",
                        "name": "description",
                        "desc": "Human-readable description of the proposal (stored on-chain)."
                    },
                    {
                        "type": "address",
                        "name": "recipient",
                        "desc": "Beneficiary of the treasury payment."
                    },
                    {
                        "type": "uint64",
                        "name": "amount",
                        "desc": "Payment amount in microALGO."
                    },
                    {
                        "type": "byte[][]",
                        "name": "signatures",
                        "desc": "Falcon-1024 signatures from M committee members."
                    },
                    {
                        "type": "uint64[]",
                        "name": "signer_indices",
                        "desc": "Indices of the signing committee members."
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "uint64",
                    "desc": "Proposal ID (0-indexed)."
                },
                "desc": "Submit a spending proposal with M-of-N Falcon signatures.\nIf the quorum is reached, the proposal is immediately executed (treasury pays out to recipient)."
            },
            {
                "name": "get_proposal_count",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "uint64"
                },
                "desc": "Return total number of proposals submitted."
            },
            {
                "name": "get_threshold",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "uint64"
                },
                "desc": "Return the DAO's signature threshold (M)."
            },
            {
                "name": "get_member_count",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "uint64"
                },
                "desc": "Return total committee size (N)."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {}
}