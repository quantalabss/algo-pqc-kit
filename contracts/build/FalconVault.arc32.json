    "contract": {
        "name": "FalconVault",
        "desc": "\n    M-of-N Post-Quantum Threshold Vault\n\n    A treasury that releases ALGO or ASAs only when M-of-N Falcon-1024\n    signatures are verified on-chain via the AVM falcon_verify opcode.\n\n    Security properties\n    -------------------\n    - Quantum-resistant: all verification uses falcon_verify (NIST FN-DSA)\n    - No single point of failure: M < N means one key loss doesn't freeze funds\n    - Replay protection: message includes nonce + recipient + amount\n    - No admin backdoor: committee is fixed at deployment\n    ",
        "methods": [
            {
                "name": "create",
                "args": [
                    {
                        "type": "uint64",
                        "name": "threshold"
                    },
                    {
                        "type": "byte[][]",
                        "name": "public_keys"
                    },
                    {
                        "type": "uint64",
                        "name": "asset_id"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Deploy the vault with an immutable M-of-N Falcon committee."
            },
            {
                "name": "bootstrap",
                "args": [
                    {
                        "type": "byte[][]",
                        "name": "public_keys"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Allocate boxes for the public keys.\nRequires the app to be funded first."
            },
            {
                "name": "release",
                "args": [
                    {
                        "type": "address",
                        "name": "recipient"
                    },
                    {
                        "type": "uint64",
                        "name": "amount"
                    },
                    {
                        "type": "byte[][]",
                        "name": "signatures"
                    },
                    {
                        "type": "uint64[]",
                        "name": "signer_indices"
                    }
                ],
                "readonly": false,
                "returns": {
                    "type": "void"
                },
                "desc": "Release funds after M-of-N Falcon-1024 verification.\nThe signed message is: itob(nonce) || recipient_bytes || itob(amount) This prevents replay attacks across different release calls."
            },
            {
                "name": "get_config",
                "args": [],
                "readonly": true,
                "returns": {
                    "type": "(uint64,uint64,uint64)"
                },
                "desc": "Return (threshold, num_signers, nonce) \u2014 read-only."
            }
        ],
        "networks": {}
    },
    "bare_call_config": {}
}